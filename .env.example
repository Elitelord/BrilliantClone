# Firebase web config - copy this file to ".env" and fill with your project's values.
# Find these in Firebase console -> Project settings -> General -> "Your apps" -> SDK setup and configuration.
# The app runs without these (it falls back to local guest mode + localStorage),
# but auth + cross-device sync require them.

VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=

# --- Phase 2: AI features ---
# AI is purely additive: with this off (or unset), the app still teaches fully.
VITE_AI_ENABLED=

# Which backend talks to the model (pick ONE when you get credentials from your team):
#
#   firebase     — default. Uses Firebase AI Logic (no separate Gemini key in .env).
#                  Needs Firebase config above + firebase init ailogic. App Check recommended.
#
#   gemini-api   — Google AI Studio / Gemini Developer API key in VITE_GEMINI_API_KEY.
#                  Good for dev/prototyping when your boss hands you a Gemini API key.
#                  WARNING: key is visible in the browser bundle — use proxy for production.
#
#   openai       — OpenAI API key in VITE_OPENAI_API_KEY (e.g. gpt-4o-mini).
#                  WARNING: key is visible in the browser bundle — use proxy for production.
#
#   proxy        — Your team's HTTPS endpoint (Cloud Function, etc.) that holds keys server-side.
#                  Set VITE_AI_PROXY_URL (+ optional VITE_AI_PROXY_TOKEN).
#
VITE_AI_PROVIDER=firebase

# Optional model name (default: gemini-flash-latest). Examples: gemini-2.5-flash-lite
VITE_AI_MODEL=

# --- gemini-api provider only ---
VITE_GEMINI_API_KEY=

# --- openai provider only (must start with VITE_ — plain OPENAI_API_KEY is NOT read) ---
VITE_OPENAI_API_KEY=

# --- proxy provider only ---
# POST endpoint. Request/response shape documented in src/lib/ai/provider/proxyProvider.ts
VITE_AI_PROXY_URL=
VITE_AI_PROXY_TOKEN=

# App Check protects Firebase AI Logic quota (firebase provider). Optional for local dev.
VITE_APPCHECK_RECAPTCHA_KEY=

# Local dev only: App Check debug token from browser console. Never set in prod.
VITE_APPCHECK_DEBUG_TOKEN=
