# Firebase web config - copy this file to ".env" and fill with your project's values.
# Find these in Firebase console -> Project settings -> General -> "Your apps" -> SDK setup and configuration.
# The app runs without these (it falls back to local guest mode + localStorage),
# but auth + cross-device sync require them.

VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=
