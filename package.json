{
  "name": "dtm-learn-by-doing",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "description": "Learn-by-doing app teaching the Demographic Transition Model (AP Human Geography), modeled on Brilliant.",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "type-check": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "preview": "vite preview",
    "deploy": "npm run build && firebase deploy --only hosting,firestore:rules"
  },
  "dependencies": {
    "d3-scale": "^4.0.2",
    "d3-shape": "^3.2.0",
    "firebase": "^12.15.0",
    "framer-motion": "^11.5.4",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-router-dom": "^6.26.2",
    "react-simple-maps": "^3.0.0",
    "zustand": "^4.5.5"
  },
  "devDependencies": {
    "@types/d3-scale": "^4.0.8",
    "@types/d3-shape": "^3.1.6",
    "@types/react": "^18.3.5",
    "@types/react-dom": "^18.3.0",
    "@types/react-simple-maps": "^3.0.6",
    "@vitejs/plugin-react": "^4.3.1",
    "autoprefixer": "^10.4.20",
    "postcss": "^8.4.47",
    "tailwindcss": "^3.4.12",
    "typescript": "^5.5.4",
    "vite": "^5.4.6",
    "vitest": "^3.2.6",
    "world-atlas": "^2.0.2"
